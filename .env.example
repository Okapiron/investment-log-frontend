VITE_API_BASE=http://localhost:8000/api/v1
# optional: API request timeout in milliseconds (default: 15000)
# VITE_API_TIMEOUT_MS=15000
# VITE_APP_VERSION=2026.03.08

# Auth (Supabase)
# local development default is disabled
VITE_AUTH_ENABLED=false
VITE_PRIVATE_MODE_ENABLED=false
# optional: local private access session duration in hours
# VITE_PRIVATE_MODE_SESSION_HOURS=12

# Public v1 release scope
# VITE_PUBLIC_V1_MODE=true
# VITE_SHOW_SBI_IMPORTS=false
# VITE_SBI_IMPORTS_BETA_LABEL=true
# VITE_ENABLE_PRICE_SANITY_CHECK=false
# VITE_ENABLE_TRADE_CHART=false

# Enable these values when using magic-link auth
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Public support contact (displayed on Help / Settings / Legal pages)
VITE_SUPPORT_EMAIL=support@tradetrace.jp
